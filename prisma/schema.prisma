// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  // url      = env("DATABASE_URL")
}

model StaffMember {
  id                    Int                    @id @default(autoincrement())
  name                  String
  createdAt             DateTime               @default(now())
  recurringAvailability RecurringAvailability[]
  overrides             AvailabilityOverride[]
}

model TimeWindow {
  id          Int                    @id @default(autoincrement())
  startTime   String
  endTime     String
  recurringId Int?
  overrideId  Int?
  recurring   RecurringAvailability? @relation(fields: [recurringId], references: [id], onDelete: Cascade)
  override    AvailabilityOverride?  @relation(fields: [overrideId], references: [id], onDelete: Cascade)
}

model RecurringAvailability {
  id            Int          @id @default(autoincrement())
  staffMemberId Int
  dayOfWeek     Int
  staffMember   StaffMember  @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  windows       TimeWindow[]
}

model AvailabilityOverride {
  id            Int          @id @default(autoincrement())
  staffMemberId Int
  date          String
  type          String
  staffMember   StaffMember  @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  windows       TimeWindow[]
}